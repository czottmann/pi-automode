{
  "name": "pi-automode",
  "version": "0.1.0",
  "description": "Claude Code-style auto mode guardrail for pi.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi",
    "pi-extension",
    "pi-package",
    "auto-mode",
    "llm",
    "coding-agent"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "build": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "files": [
    "extensions",
    "examples",
    "README.md"
  ],
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.79.3",
    "@earendil-works/pi-coding-agent": "^0.79.3",
    "@earendil-works/pi-tui": "^0.79.3",
    "@types/node": "^24.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0"
  }
}
